# Copy this file to .env and fill in your values
# Configure EITHER Azure OpenAI OR standard OpenAI (not both)

# =============================================================================
# Server Configuration
# =============================================================================
# Host and port for the uvicorn server
UVICORN_HOST=0.0.0.0
UVICORN_PORT=3001

# =============================================================================
# Azure OpenAI Configuration (checked first)
# =============================================================================
# Your Azure OpenAI endpoint URL (e.g., https://your-resource.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=

# The deployment name for your model — must support vision (e.g., gpt-5.2-chat)
AZURE_OPENAI_DEPLOYMENT=

# --- Authentication (choose ONE) ---

# Option 1: API key authentication (for local development or non-Azure hosts)
AZURE_OPENAI_API_KEY=

# Option 2: Managed Identity authentication (for Azure-hosted containers)
# Set to 'true' to use DefaultAzureCredential instead of an API key.
# Works with system-assigned and user-assigned managed identities, Azure CLI, etc.
# AZURE_USE_MANAGED_IDENTITY=false

# Optional: Client ID for a user-assigned managed identity
# Only needed when AZURE_USE_MANAGED_IDENTITY=true and using a user-assigned identity
# AZURE_CLIENT_ID=

# Azure Application Insights connection string for Agent Framework telemetry (optional)
# When set, traces, logs, and metrics are exported to Azure Monitor
APPLICATIONINSIGHTS_CONNECTION_STRING=

# API version (optional, default: 2024-12-01-preview)
# OPENAI_API_VERSION=2024-12-01-preview

# =============================================================================
# Standard OpenAI Configuration (used if Azure not configured)
# =============================================================================
# Your OpenAI API key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Model name to use — must support vision (optional, default: gpt-5.2-chat)
# OPENAI_MODEL=gpt-5.2-chat

# Custom base URL for OpenAI-compatible APIs (optional)
# Useful for local LLMs or alternative providers (e.g., http://localhost:1234/v1)
# OPENAI_BASE_URL=

# =============================================================================
# UI Configuration
# =============================================================================
# Set to 'true' to show the web-based UI for interacting with the agent
# SHOW_UI=false
# UI_PORT=3002  # Port for the UI (only needed if SHOW_UI=true, default: 3002)

# =============================================================================
# Docker Compose Configuration
# =============================================================================
# User and group ID for the container (optional, default: 1000:1000)
# UID_GID=1000:1000

# =============================================================================
# Logging Configuration
# =============================================================================
# Set to 'true' to write logs and reports to files
# Logs are saved to server/.output/logs/, reports to server/.output/reports/
# and Agent Framework threads to server/.output/agents/
# WRITE_TO_FILE=false

# =============================================================================
# OAuth Configuration
# =============================================================================
# These optional settings are used to enable OAuth authentication for the UI.
# If not set, OAuth authentication is disabled.
# OAUTH_ISSUER=<your OAuth issuer URL, e.g. https://your-domain.auth0.com>
# OAUTH_CLIENT_ID=<your OAuth client ID>
# OAUTH_CLIENT_SECRET=<your OAuth client secret>
# SESSION_SECRET=<any random string, e.g. openssl rand -hex 32>
